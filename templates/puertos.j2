{# Template puertos acceso y trunk #}
{% for puerto in trunks %}
interface {{ puerto }}
 description TRUNK
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 1,10,20,30,40,50
{% endfor %}
{% for puerto in acceso_datos_voz %}
interface {{ puerto }}
 description ACCESO-DATOS-VOZ
 switchport mode access
 switchport access vlan 10
 switchport voice vlan 20
 spanning-tree portfast
{% endfor %}
{% for puerto in acceso_ap %}
interface {{ puerto }}
 description ACCESO-AP
 switchport mode access
 switchport access vlan 30
 spanning-tree portfast
{% endfor %}
{% for puerto in acceso_servidores %}
interface {{ puerto }}
 description ACCESO-SERVIDOR
 switchport mode access
 switchport access vlan 40
 spanning-tree portfast
{% endfor %}
{% for puerto in acceso_invitados %}
interface {{ puerto }}
 description ACCESO-INVITADOS
 switchport mode access
 switchport access vlan 50
 spanning-tree portfast
{% endfor %}